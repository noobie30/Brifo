{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@brifo/shared": ["packages/shared/src"],
      "@brifo/shared/*": ["packages/shared/src/*"],
      "@brifo/ui": ["packages/ui/src"],
      "@brifo/ui/*": ["packages/ui/src/*"]
    }
  }
}
